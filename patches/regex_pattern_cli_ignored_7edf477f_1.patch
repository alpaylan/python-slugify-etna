From 7edf477f64b65ffe22c966d6a8dcc3edd0fb6997 Mon Sep 17 00:00:00 2001
From: ETNA <etna@example.invalid>
Date: Mon, 27 Apr 2026 12:15:27 +0100
Subject: [PATCH] Fix --regex-pattern being ignored by the CLI

The ``--regex-pattern`` argument was parsed by argparse but never
forwarded into the ``slugify()`` call from ``slugify_params()``. As a
result, calling the CLI with ``--regex-pattern X`` had no effect on the
resulting slug.

Fixes #175.
---
 slugify/__main__.py | 1 +
 1 file changed, 1 insertion(+)

diff --git a/slugify/__main__.py b/slugify/__main__.py
index 4e6b3d9..6e8109d 100644
--- a/slugify/__main__.py
+++ b/slugify/__main__.py
@@ -76,6 +76,7 @@ def slugify_params(args: argparse.Namespace) -> dict[str, Any]:
         save_order=args.save_order,
         separator=args.separator,
         stopwords=args.stopwords,
+        regex_pattern=args.regex_pattern,
         lowercase=args.lowercase,
         replacements=args.replacements,
         allow_unicode=args.allow_unicode
--
2.0.0
